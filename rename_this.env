# ── LLM Provider (choose one) ──────────────────────────────────────
# Option A: OpenAI (easiest to get started)
OPENAI_API_KEY=sk-...

# Option B: Groq (free tier, fast, use llama-3.1-8b-instant)
GROQ_API_KEY=gsk_...

# Option C: Local Ollama → no key needed, just run `ollama pull mistral`
# Set USE_OLLAMA=true and leave API keys blank

USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding model ─────────────────────────────────────────────────
# "local"  → sentence-transformers (free, runs on CPU)
# "openai" → text-embedding-3-small (better quality, costs ~$0.02/1M tokens)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# ── Vector store ────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./vectorstore/chroma_db

# ── Generation model ────────────────────────────────────────────────
LLM_PROVIDER=ollama        # openai | groq | ollama
LLM_MODEL=llama3.2:latest  # or: llama-3.1-8b-instant (groq) | mistral (ollama)
LLM_TEMPERATURE=0.0

# ── RAG parameters ─────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVER_K=5              # number of docs to retrieve per query
