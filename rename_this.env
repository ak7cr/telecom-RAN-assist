# ── LLM Provider — choose ONE block ────────────────────────────────

# Option A: Groq  (recommended — free tier, fast)
# Sign up at https://console.groq.com
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=gsk_...

# Option B: OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Option C: Ollama  (local, no API key needed)
# Run: ollama pull llama3.2
# USE_OLLAMA=true
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2:latest
# OLLAMA_BASE_URL=http://localhost:11434

# Option D: Tele-LLMs via HuggingFace  (domain-specific, needs GPU)
# Fine-tuned on 2.5B telecom tokens (3GPP + arXiv + Wikipedia)
# Sizes: TinyLlama-1.1B-Instruct-Tele | Llama-3.2-3B-Instruct-Tele | Llama-3-8B-Instruct-Tele
# LLM_PROVIDER=huggingface
# LLM_MODEL=AliMaatouk/Llama-3.2-3B-Instruct-Tele
# HF_DEVICE_MAP=auto       # auto | cpu | cuda:0
# HF_MAX_NEW_TOKENS=512

# ── Embeddings ──────────────────────────────────────────────────────
# "local"  → sentence-transformers (free, CPU-friendly, no key needed)
# "openai" → text-embedding-3-small (better quality, ~$0.02/1M tokens)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# ── Vector store ────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./vectorstore/chroma_db

# ── RAG parameters ──────────────────────────────────────────────────
LLM_TEMPERATURE=0.0
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVER_K=5       # number of docs returned per query
